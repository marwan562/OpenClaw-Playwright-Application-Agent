# LLM API configuration for QuestionAnswerer (defaults to local OpenClaw 9router)
LLM_API_URL=http://127.0.0.1:20128/v1
LLM_API_KEY=your_openclaw_llm_api_key_here
LLM_MODEL=Test

# Resume path
RESUME_PATH=/path/to/your/resume.pdf

# Browser persistence configuration (to reuse logged-in LinkedIn sessions)
BROWSER_USER_DATA_DIR=/path/to/your/chrome-profile

# Playwright configs
HEADLESS=false
SLOMO_MS=500
ACTION_TIMEOUT_MS=15000
NAVIGATION_TIMEOUT_MS=30000

# Telegram Notifications (linked with OpenClaw configuration)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
